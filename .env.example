# Discord bot token from the Discord developer portal.
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Pollinations API key for the OpenAI-compatible text endpoint.
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# Model used for text generation.
POLLINATIONS_MODEL=kimi

# Optional override for the Pollinations OpenAI-compatible base URL.
POLLINATIONS_BASE_URL=https://gen.pollinations.ai/v1

# Guild to sync slash commands to during development. Leave blank to sync globally.
COMMAND_GUILD_ID=1480820197236674714

# The only guild where the bot will answer mention/reply questions.
ALLOWED_GUILD_ID=1480820197236674714

# Users must have this role to use the bot.
ALLOWED_ROLE_ID=1480853263745155162

# Owner-only bot commands are restricted to this user ID.
BOT_OWNER_USER_ID=861620168370683924

# IntenseRP Next documentation endpoints.
DOCS_BASE_URL=https://intense-rp-next.readthedocs.io/en/latest/
DOCS_SEARCH_INDEX_URL=https://intense-rp-next.readthedocs.io/en/latest/search.json

# Optional local override for the docs search index during development.
DOCS_SEARCH_INDEX_FILE=

APP_VERSION_URL=https://raw.githubusercontent.com/LyubomirT/intense-rp-next/refs/heads/v2-rewrite/version.json

# Rate limits.
CHANNEL_RATE_LIMIT_COUNT=1
CHANNEL_RATE_LIMIT_WINDOW_SECONDS=60
GLOBAL_RATE_LIMIT_COUNT=40
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=3600

# Conversation memory.
CONVERSATION_MAX_MESSAGES=10
CONVERSATION_INACTIVITY_SECONDS=3600

# Cache refresh cadence.
CACHE_REFRESH_INTERVAL_SECONDS=21600

# Retrieval tuning.
DOCS_FETCH_CONCURRENCY=5
RAG_CHUNK_SIZE_CHARS=1400
RAG_CHUNK_OVERLAP_CHARS=250
RAG_SEARCH_LIMIT=6

# Runtime settings.
HTTP_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
BOT_DATA_DIR=data

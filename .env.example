# Discord bot token for Reader of the Manual.
DISCORD_BOT_TOKEN=

# Pollinations API key used for both the selector model and the final answer model.
POLLINATIONS_API_KEY=

# Final response model used after page selection.
POLLINATIONS_MODEL=kimi

# Cheap selector model that sees the full cached docs corpus first.
POLLINATIONS_SELECTOR_MODEL=openai

# Pollinations OpenAI-compatible API base URL.
POLLINATIONS_BASE_URL=https://gen.pollinations.ai/v1

# Optional development guild for fast slash-command sync. Leave blank for global sync.
COMMAND_GUILD_ID=

# Guild where the bot is allowed to answer.
ALLOWED_GUILD_ID=1480820197236674714

# Role required to use the bot.
ALLOWED_ROLE_ID=1480853263745155162

# Owner user ID allowed to force cache refreshes.
BOT_OWNER_USER_ID=861620168370683924

# IntenseRP Next docs home URL.
DOCS_BASE_URL=https://intense-rp-next.readthedocs.io/en/latest/

# Read the Docs search index used to discover pages.
DOCS_SEARCH_INDEX_URL=https://intense-rp-next.readthedocs.io/en/latest/search.json

# Optional local path to a search.json file for offline/dev testing.
DOCS_SEARCH_INDEX_FILE=

# Version file used to detect when the cache should refresh.
APP_VERSION_URL=https://raw.githubusercontent.com/LyubomirT/intense-rp-next/refs/heads/v2-rewrite/version.json

# Per-channel cooldown settings.
CHANNEL_RATE_LIMIT_COUNT=1
CHANNEL_RATE_LIMIT_WINDOW_SECONDS=60

# Global cooldown settings.
GLOBAL_RATE_LIMIT_COUNT=40
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=3600

# Conversation memory settings.
CONVERSATION_MAX_MESSAGES=10
CONVERSATION_INACTIVITY_SECONDS=3600

# Docs cache refresh interval in seconds.
CACHE_REFRESH_INTERVAL_SECONDS=21600

# Concurrent docs page fetches while rebuilding the cache.
DOCS_FETCH_CONCURRENCY=5

# Max number of docs pages the selector may hand to the final model.
DOCS_SELECTOR_PAGE_LIMIT=4

# Shared HTTP timeout for docs fetches and Pollinations calls.
HTTP_TIMEOUT_SECONDS=30

# Logging verbosity.
LOG_LEVEL=INFO

# Directory for the SQLite database and cache metadata.
BOT_DATA_DIR=data

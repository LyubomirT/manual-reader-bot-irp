# Discord bot token from the Discord developer portal.
DISCORD_BOT_TOKEN=replace_me

# Pollinations API key used for both the selector and answer models.
POLLINATIONS_API_KEY=replace_me
POLLINATIONS_MODEL=kimi
POLLINATIONS_SELECTOR_MODEL=openai
POLLINATIONS_BASE_URL=https://gen.pollinations.ai/v1

# Optional: set this to a test guild ID for near-instant slash command updates.
COMMAND_GUILD_ID=

# Server access control.
ALLOWED_GUILD_ID=1480820197236674714
ALLOWED_ROLE_ID=1480853263745155162
BOT_OWNER_USER_ID=861620168370683924

# Optional moderation shortcut. When false, the LLM cannot auto-block users.
AI_TRIGGERED_BANS_ENABLED=false

# IntenseRP Next documentation sources.
DOCS_BASE_URL=https://intense-rp-next.readthedocs.io/en/latest/
DOCS_SEARCH_INDEX_URL=https://intense-rp-next.readthedocs.io/en/latest/search.json

# Optional local override for offline testing.
DOCS_SEARCH_INDEX_FILE=

# Upstream app version file used to decide whether the docs cache should refresh.
APP_VERSION_URL=https://raw.githubusercontent.com/LyubomirT/intense-rp-next/refs/heads/v2-rewrite/version.json

# Rate limits.
CHANNEL_RATE_LIMIT_COUNT=2
CHANNEL_RATE_LIMIT_WINDOW_SECONDS=60
GLOBAL_RATE_LIMIT_COUNT=48
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=3600

# Conversation memory.
CONVERSATION_MAX_MESSAGES=10
CONVERSATION_INACTIVITY_SECONDS=3600

# Docs cache / retrieval tuning.
CACHE_REFRESH_INTERVAL_SECONDS=21600
STATUS_ROTATION_INTERVAL_SECONDS=3600

# Optional status phrase file. See statuses.example.txt for the format.
STATUS_PHRASES_FILE=
DOCS_FETCH_CONCURRENCY=5
DOCS_SELECTOR_PAGE_LIMIT=4

# Runtime behavior.
HTTP_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
BOT_DATA_DIR=data
